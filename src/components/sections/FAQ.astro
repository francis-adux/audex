---
import FAQItem from '../cards/FAQItem.astro';

export interface Props {
  title?: string;
  items: { question: string; answer: string }[];
  sectionClass?: string;
}

const { title = 'Questions fréquentes', items, sectionClass = 'section section-light' } = Astro.props;
---

<section class={sectionClass}>
  <div class="container-audex">
    <div class="section-header">
      <h2>{title}</h2>
    </div>
    <div class="faq-list">
      {items.map((item) => <FAQItem question={item.question} answer={item.answer} />)}
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.faq-question');
    if (!btn) return;
    const item = btn.parentElement;
    const answer = item.querySelector('.faq-answer');
    const isActive = item.classList.toggle('active');
    btn.setAttribute('aria-expanded', String(isActive));
    if (isActive) {
      answer.style.maxHeight = answer.scrollHeight + 'px';
    } else {
      answer.style.maxHeight = '0px';
    }
  });
</script>
