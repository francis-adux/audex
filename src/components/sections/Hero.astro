---
import { company } from '../../data/company';

export interface Props {
  title: string;
  subtitle: string;
  image: string;
  imageWebp?: string;
  imageAlt?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  title,
  subtitle,
  image,
  imageWebp,
  imageAlt = '',
  ctaLabel = 'Planifier une consultation',
  ctaHref = '/nous-joindre',
} = Astro.props;
---

<section class="hero" id="hero">
  <div class="hero-bg">
    <picture>
      {imageWebp && <source srcset={imageWebp} type="image/webp" />}
      <img src={image} alt={imageAlt} width="1920" height="1080" />
    </picture>
    <div class="hero-overlay"></div>
  </div>
  <div class="hero-content">
    <h1>{title}</h1>
    <p class="hero-subtitle">{subtitle}</p>
    <div class="hero-actions">
      <a href={ctaHref} class="btn btn-gold btn-lg">{ctaLabel}</a>
      <p class="hero-phone">ou appelez le <a href={company.phoneHref}>{company.phone}</a></p>
    </div>
  </div>
</section>
