---
export interface ValuePillar {
  title: string;
  emoji?: string;
  points: string[];
}

export interface Props {
  eyebrow?: string;
  title?: string;
  intro?: string;
  pillars?: ValuePillar[];
}

const defaultPillars: ValuePillar[] = [
  {
    title: 'Excellence du service',
    emoji: '⭐',
    points: [
      'Écoute active',
      "Utilisation d'outils technologiques",
      "Maintien d'une image professionnelle distincte",
      'Service client hors pair',
    ],
  },
  {
    title: "Esprit d'équipe",
    emoji: '🤝',
    points: [
      'Climat de travail agréable, respectueux et équitable',
      'Confiance et responsabilité',
      'Transparence et résolution constructive des conflits',
      'Priorisation des résultats collectifs',
    ],
  },
  {
    title: 'Innovation et amélioration continue',
    emoji: '💡',
    points: [
      'Encouragement des nouvelles idées',
      "Promotion de la créativité et de l'initiative",
      'Optimisation des processus de travail',
      'Engagement et proactivité',
      'Acceptation du changement',
    ],
  },
];

const {
  eyebrow = 'Nos valeurs',
  title = 'Pour quelle raison Audex se lève le matin?',
  intro = "Notre mission est de pratiquer le droit en plaçant l'écoute au cœur de chaque démarche, pour guider avec justesse et empathie. Ici, nous prenons le temps de comprendre et de vous accompagner vers le prochain chapitre.",
  pillars = defaultPillars,
} = Astro.props;
---

<section class="section section-light values-section">
  <div class="container-audex">
    <div class="values-header">
      <p class="eyebrow">{eyebrow} <span aria-hidden="true">❤️</span></p>
      <h2>{title}</h2>
      <p class="values-intro">{intro}</p>
    </div>

    <div class="values-grid">
      {pillars.map((p) => (
        <div class="value-card">
          <div class="value-emoji" aria-hidden="true">{p.emoji}</div>
          <h3>{p.title}</h3>
          <ul>
            {p.points.map((point) => <li>{point}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .values-header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 3rem;
  }
  .eyebrow {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }
  .values-section h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin-bottom: 1.25rem;
  }
  .values-intro {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #555;
  }
  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .value-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem 1.75rem;
    transition: transform 0.2s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    border-top: 4px solid var(--color-gold);
  }
  .value-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }
  .value-emoji {
    font-size: 2.2rem;
    line-height: 1;
    margin-bottom: 0.75rem;
  }
  .value-card h3 {
    font-size: 1.25rem;
    color: var(--color-navy);
    margin-bottom: 1rem;
  }
  .value-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .value-card li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.6rem;
    font-size: 0.95rem;
    color: var(--color-text);
    line-height: 1.5;
  }
  .value-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 8px;
    height: 8px;
    background: var(--color-gold);
    border-radius: 50%;
  }
  .value-card li:last-child {
    margin-bottom: 0;
  }
  @media (min-width: 768px) {
    .values-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }
</style>
