---
import Breadcrumb, { type BreadcrumbItem } from '../layout/Breadcrumb.astro';

export interface Props {
  title: string;
  subtitle?: string;
  image?: string;
  imageWebp?: string;
  imageAlt?: string;
  breadcrumb: BreadcrumbItem[];
}

const { title, subtitle, image, imageWebp, imageAlt = '', breadcrumb } = Astro.props;
---

<section class="hero-internal">
  {image && (
    <div class="hero-bg">
      <picture>
        {imageWebp && <source srcset={imageWebp} type="image/webp" />}
        <img src={image} alt={imageAlt} width="1920" height="800" />
      </picture>
    </div>
  )}
  <div class="hero-content">
    <Breadcrumb items={breadcrumb} />
    <h1>{title}</h1>
    {subtitle && <p class="hero-subtitle">{subtitle}</p>}
  </div>
</section>
