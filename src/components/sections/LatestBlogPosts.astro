---
import { getCollection } from 'astro:content';

export interface Props {
  limit?: number;
  title?: string;
  subtitle?: string;
}

const { limit = 3, title = 'Derniers articles', subtitle = "Notre équipe partage régulièrement des analyses pour vulgariser le droit." } = Astro.props;

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, limit);

const formatDate = (d: Date) =>
  d.toLocaleDateString('fr-CA', { year: 'numeric', month: 'long', day: 'numeric' });
---

{posts.length > 0 && (
  <section class="section latest-blog" id="derniers-articles">
    <div class="container-audex">
      <div class="section-header">
        <p class="eyebrow">Blogue</p>
        <h2>{title}</h2>
        <p>{subtitle}</p>
      </div>

      <div class="blog-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="blog-card">
            {post.data.image && (
              <div class="blog-card-image">
                <img src={post.data.image} alt={post.data.title} loading="lazy" />
              </div>
            )}
            <div class="blog-card-body">
              <div class="blog-card-meta">
                <time datetime={post.data.publishDate.toISOString()}>{formatDate(post.data.publishDate)}</time>
                {post.data.tags && post.data.tags.length > 0 && (
                  <span class="blog-card-tag">{post.data.tags[0]}</span>
                )}
              </div>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <span class="blog-card-link">Lire l'article →</span>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-3">
        <a href="/blog" class="btn btn-outline-dark">Voir tous les articles</a>
      </div>
    </div>
  </section>
)}

<style>
  .eyebrow {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    transition: transform 0.2s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .blog-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    border-color: var(--color-gold);
    color: var(--color-text);
  }
  .blog-card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-light);
  }
  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .blog-card-body {
    padding: 1.5rem 1.5rem 1.75rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .blog-card-tag {
    background: var(--color-light);
    color: var(--color-navy);
    padding: 0.2rem 0.65rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.7rem;
  }
  .blog-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }
  .blog-card p {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1rem;
  }
  .blog-card-link {
    color: var(--color-gold);
    font-weight: 600;
    font-size: 0.95rem;
    transition: transform 0.2s ease;
  }
  .blog-card:hover .blog-card-link {
    transform: translateX(3px);
    display: inline-block;
  }
  @media (min-width: 640px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
