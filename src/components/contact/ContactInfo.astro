---
import OfficeLocation from './OfficeLocation.astro';
import { offices } from '../../data/offices';
import { company } from '../../data/company';

export interface Props {
  showOffices?: 'all' | 'quebec' | 'donnacona' | 'none';
  mapHeight?: number;
  remoteServiceArea?: string;
}

const { showOffices = 'all', mapHeight = 200, remoteServiceArea } = Astro.props;

const filtered = offices.filter((o) => {
  if (showOffices === 'none') return false;
  if (showOffices === 'quebec') return o.short === 'Québec';
  if (showOffices === 'donnacona') return o.short === 'Donnacona';
  return true;
});
---

<div class="contact-info-wrap">
  <div class="contact-phone-block">
    <a href={company.phoneHref} class="contact-big-phone">{company.phone}</a>
    <p class="contact-phone-label">Téléphone et texto</p>
    {company.fax && (
      <p class="contact-fax">Télécopieur : {company.fax}</p>
    )}
    <a href={company.emailHref} class="contact-email">{company.email}</a>
  </div>

  <div class="contact-hours">
    <h3>Heures d'ouverture</h3>
    <p set:html={company.hours.replace(/\n/g, '<br />')} />
  </div>

  {remoteServiceArea && (
    <div class="contact-location">
      <h3>Service offert à distance</h3>
      <p>Nous accompagnons les résidents et entreprises {remoteServiceArea} par téléphone et visioconférence — pas de déplacement nécessaire.</p>
    </div>
  )}

  {filtered.map((o) => <OfficeLocation office={o} mapHeight={mapHeight} />)}
</div>

<style>
  .contact-phone-label {
    font-size: 0.85rem;
    color: #777;
    margin: -0.25rem 0 0.5rem;
    letter-spacing: 0.02em;
  }
  .contact-fax {
    font-size: 0.95rem;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
</style>
