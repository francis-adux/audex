---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="Blogue - Mon Site" description="Articles récents">
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-12">Blogue</h1>

    {posts.length === 0 ? (
      <p class="text-gray-600">Aucun article publié pour le moment.</p>
    ) : (
      <div class="grid md:grid-cols-2 gap-8">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="block border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition">
            {post.data.image && (
              <img src={post.data.image} alt={post.data.title} class="w-full h-48 object-cover" />
            )}
            <div class="p-6">
              <time class="text-sm text-gray-500">
                {post.data.publishDate.toLocaleDateString('fr-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2 class="text-2xl font-semibold mt-2 mb-2">{post.data.title}</h2>
              <p class="text-gray-600">{post.data.description}</p>
              <p class="text-sm text-gray-500 mt-3">Par {post.data.author}</p>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
