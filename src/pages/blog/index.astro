---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroInternal from '../../components/sections/HeroInternal.astro';
import CtaBlock from '../../components/sections/CtaBlock.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('fr-CA', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Articles juridiques | AUDEX Avocats"
  description="Articles d'analyse juridique signés par l'équipe d'AUDEX Avocats. Droit familial, criminel, civil, commercial et plus. Une approche humaine du droit."
  headerSolid
>
  <HeroInternal
    title="Articles juridiques"
    subtitle="Notre équipe partage régulièrement des analyses pour vulgariser le droit et vous aider à mieux comprendre vos options."
    breadcrumb={[{ label: 'Articles' }]}
  />

  <section class="section">
    <div class="container-audex">
      {posts.length === 0 ? (
        <p style="text-align:center; color:#666;">Aucun article publié pour le moment.</p>
      ) : (
        <div class="blog-archive">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="blog-card">
              {post.data.image && (
                <div class="blog-card-image">
                  <img src={post.data.image} alt={post.data.title} loading="lazy" />
                </div>
              )}
              <div class="blog-card-body">
                <div class="blog-card-meta">
                  <time datetime={post.data.publishDate.toISOString()}>{formatDate(post.data.publishDate)}</time>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <span class="blog-card-tag">{post.data.tags[0]}</span>
                  )}
                </div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="blog-card-link">Lire l'article →</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <CtaBlock title="Une question juridique vous préoccupe?" />
</BaseLayout>

<style>
  .blog-archive {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    transition: transform 0.2s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .blog-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    border-color: var(--color-gold);
    color: var(--color-text);
  }
  .blog-card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-light);
  }
  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .blog-card-body {
    padding: 1.5rem 1.5rem 1.75rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .blog-card-tag {
    background: var(--color-light);
    color: var(--color-navy);
    padding: 0.2rem 0.65rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.7rem;
  }
  .blog-card h2 {
    font-size: 1.2rem;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }
  .blog-card p {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1rem;
  }
  .blog-card-link {
    color: var(--color-gold);
    font-weight: 600;
    font-size: 0.95rem;
  }
  @media (min-width: 640px) {
    .blog-archive {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .blog-archive {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
