---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Merci - Mon Site" description="Message reçu">
  <section class="max-w-2xl mx-auto px-4 py-24 text-center">
    <h1 class="text-4xl font-bold mb-4">Merci!</h1>
    <p class="text-xl text-gray-600 mb-8">
      Votre message a bien été reçu. Nous vous répondrons dans les plus brefs délais.
    </p>
    <a href="/" class="inline-block bg-brand text-white px-8 py-3 rounded font-semibold hover:bg-brand-dark transition">
      Retour à l'accueil
    </a>
  </section>
</BaseLayout>
