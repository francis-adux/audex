---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const landings = await getCollection('landings', ({ data }) => data.published);
  return landings.map((landing) => ({
    params: { slug: landing.slug },
    props: { landing },
  }));
}

const { landing } = Astro.props;
const { Content } = await landing.render();
const formName = `landing-${landing.slug}`;
---

<BaseLayout title={landing.data.title} description={landing.data.description} image={landing.data.image}>
  <section class="bg-gradient-to-br from-brand to-brand-dark text-white py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-5xl font-bold mb-6">{landing.data.heroTitle}</h1>
      <p class="text-xl mb-8 max-w-2xl mx-auto">{landing.data.heroSubtitle}</p>
      <a href="#contact" class="inline-block bg-white text-brand px-8 py-3 rounded font-semibold hover:bg-gray-100 transition">
        {landing.data.ctaText}
      </a>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 py-16">
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </section>

  <section id="contact" class="bg-gray-50 py-16">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-3xl font-bold mb-4 text-center">Nous contacter</h2>
      <p class="text-gray-600 mb-8 text-center">
        Laissez-nous vos coordonnées, nous vous rappellerons rapidement.
      </p>

      <form
        name={formName}
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/merci"
        class="space-y-4 bg-white p-8 rounded-lg shadow"
      >
        <input type="hidden" name="form-name" value={formName} />
        <input type="hidden" name="landing-source" value={landing.slug} />
        <p class="hidden">
          <label>Ne pas remplir: <input name="bot-field" /></label>
        </p>

        <div>
          <label for="nom" class="block text-sm font-medium mb-1">Nom</label>
          <input type="text" name="nom" id="nom" required class="w-full border border-gray-300 rounded px-4 py-2" />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium mb-1">Courriel</label>
          <input type="email" name="email" id="email" required class="w-full border border-gray-300 rounded px-4 py-2" />
        </div>

        <div>
          <label for="telephone" class="block text-sm font-medium mb-1">Téléphone</label>
          <input type="tel" name="telephone" id="telephone" class="w-full border border-gray-300 rounded px-4 py-2" />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium mb-1">Message</label>
          <textarea name="message" id="message" rows="4" class="w-full border border-gray-300 rounded px-4 py-2"></textarea>
        </div>

        <button type="submit" class="w-full bg-brand text-white px-8 py-3 rounded font-semibold hover:bg-brand-dark transition">
          Envoyer
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
