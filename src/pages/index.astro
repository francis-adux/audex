---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Stats from '../components/sections/Stats.astro';
import Pillars from '../components/sections/Pillars.astro';
import ServicesGrid from '../components/sections/ServicesGrid.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import GoogleReviewsCTA from '../components/sections/GoogleReviewsCTA.astro';
import Stakes from '../components/sections/Stakes.astro';
import CtaFinal from '../components/sections/CtaFinal.astro';

const title = 'Avocats à Québec | AUDEX Avocats — Accessibles depuis 2013';
const description = "Cabinet d'avocats à Québec depuis 2013. 2 500+ dossiers traités, interventions dans 29 districts judiciaires. Première consultation à tarif fixe. Appelez le 418-462-1010.";
---

<BaseLayout title={title} description={description}>
  <Hero
    title="Vous faites face à une situation juridique stressante?"
    subtitle="Chez Audex, on vous écoute d'abord. On vous guide ensuite."
    image="/images/hero-banner.png"
    imageWebp="/images/hero-banner.webp"
    imageAlt="Équipe d'avocats AUDEX en réunion avec un client"
  />

  <Stats />

  <Pillars />

  <ServicesGrid />

  <HowItWorks />

  <GoogleReviewsCTA />

  <Stakes />

  <CtaFinal />
</BaseLayout>
