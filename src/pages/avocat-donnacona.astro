---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroInternal from '../components/sections/HeroInternal.astro';
import ServicesGrid from '../components/sections/ServicesGrid.astro';
import ContactInfo from '../components/contact/ContactInfo.astro';
import FAQ from '../components/sections/FAQ.astro';
import CtaBlock from '../components/sections/CtaBlock.astro';
import { services } from '../data/services';

const title = 'Avocat pour Donnacona | AUDEX Avocats — Service à distance';
const description = "Avocat pour les résidents de Donnacona, Portneuf. AUDEX Avocats accompagne par téléphone et visioconférence — droit familial, civil, commercial, criminel et plus. 418-462-1010.";

const faq = [
  { question: "Pourquoi choisir AUDEX Avocats pour un dossier à Donnacona?", answer: "AUDEX Avocats accompagne les résidents de Donnacona et de la MRC de Portneuf depuis plusieurs années. Nos consultations se déroulent par téléphone et visioconférence, ce qui vous évite de vous déplacer à Québec tout en bénéficiant de l'expertise complète de notre équipe. Première consultation à tarif fixe." },
  { question: "Quels sont les services juridiques disponibles pour les résidents de Donnacona?", answer: "Tous nos champs de pratique sont accessibles à distance : droit familial, médiation familiale, droit civil, droit commercial, droit criminel et pénal, droit administratif, droit municipal, droit de l'emploi et droit de la jeunesse. Vous bénéficiez de l'expertise complète de notre équipe directement depuis chez vous." },
  { question: "Comment se déroule une consultation à distance avec AUDEX?", answer: "Vous prenez rendez-vous par téléphone ou via notre formulaire en ligne. Le jour du rendez-vous, votre avocat vous contacte par téléphone ou via Microsoft Teams selon votre préférence. La consultation se déroule comme une rencontre en personne — vous pouvez poser toutes vos questions et obtenir un plan d'action clair." },
  { question: "Est-ce possible d'avoir un rendez-vous le soir ou la fin de semaine?", answer: "Oui. Bien que nos heures régulières soient du lundi au vendredi de 8 h 30 à 17 h, nous offrons des rendez-vous en soirée et les fins de semaine sur demande. Contactez-nous au 418-462-1010 pour vérifier les disponibilités." },
  { question: "AUDEX Avocats accepte-t-il l'aide juridique?", answer: "Pour savoir si vous êtes admissible à l'aide juridique et si nos avocats peuvent vous recevoir sous ce programme, appelez-nous au 418-462-1010. Nous pourrons vérifier votre admissibilité et vous orienter vers les ressources appropriées." },
];
---

<BaseLayout title={title} description={description} headerSolid>
  <HeroInternal
    title="Un avocat pour Donnacona — sans déplacement"
    subtitle="Tous nos services juridiques offerts par téléphone et visioconférence aux résidents de Donnacona. Première consultation à tarif fixe."
    breadcrumb={[{ label: 'Avocat à Donnacona' }]}
  />

  <section class="section">
    <div class="container-audex">
      <div class="about-content">
        <h2>Un avocat accessible aux résidents de Donnacona</h2>
        <p>AUDEX Avocats accompagne les citoyens et entreprises de Donnacona à travers leurs démarches juridiques — directement depuis leur domicile. Nos consultations à distance vous donnent accès à une équipe complète d'avocats sans avoir à vous déplacer à Québec.</p>
        <p>Nous savons qu'avoir besoin d'un avocat peut être stressant. C'est pourquoi notre priorité est de rendre l'expérience aussi simple et humaine que possible. Avec nous, vous gagnez du temps, vous épargnez le déplacement, et vous restez en contrôle de votre dossier.</p>
        <p>De la première consultation au règlement de votre dossier, nous sommes là pour vous écouter, vous conseiller et vous représenter avec rigueur et bienveillance.</p>
      </div>
    </div>
  </section>

  <ServicesGrid
    title="Services juridiques offerts aux résidents de Donnacona"
    subtitle="L'ensemble de nos champs de pratique est accessible à distance."
    services={services}
    showBlurb
  />

  <section class="section">
    <div class="container-audex">
      <div class="contact-grid" style="grid-template-columns: 1fr;">
        <ContactInfo showOffices="none" remoteServiceArea="de Donnacona et de la MRC de Portneuf" />
      </div>
    </div>
  </section>

  <FAQ title="Questions fréquentes — Avocat pour Donnacona" items={faq} />

  <CtaBlock title="Discutez avec un avocat — sans vous déplacer" />
</BaseLayout>
