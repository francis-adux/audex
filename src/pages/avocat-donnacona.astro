---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroInternal from '../components/sections/HeroInternal.astro';
import ServicesGrid from '../components/sections/ServicesGrid.astro';
import ContactInfo from '../components/contact/ContactInfo.astro';
import FAQ from '../components/sections/FAQ.astro';
import CtaBlock from '../components/sections/CtaBlock.astro';
import { services } from '../data/services';

const title = 'Avocat à Donnacona | AUDEX Avocats — Services juridiques locaux';
const description = "Avocat à Donnacona, Portneuf. Cabinet AUDEX Avocats : droit familial, criminel, commercial et civil. Bureau au 100, route 138, bureau 120. 418-462-1010.";

const faq = [
  { question: "Pourquoi choisir AUDEX Avocats à Donnacona?", answer: "AUDEX Avocats offre un service de proximité à Donnacona depuis plusieurs années. Notre bureau au 100, route 138 vous permet de consulter un avocat compétent sans avoir à vous déplacer à Québec. Notre équipe connaît la réalité de la communauté de Donnacona et de Portneuf. Première consultation à tarif fixe." },
  { question: "Quels sont les services juridiques disponibles à Donnacona?", answer: "Notre bureau de Donnacona offre tous nos champs de pratique : droit familial, médiation familiale, droit civil, droit commercial, droit criminel et pénal, droit administratif, droit municipal, droit de l'emploi et droit de la jeunesse. Vous bénéficiez de l'expertise complète de notre équipe, directement dans votre communauté." },
  { question: "Comment me rendre au bureau d'AUDEX Avocats à Donnacona?", answer: "Notre bureau est situé au 100, route 138, bureau 120, Donnacona (Québec) G3M 1B5. Le bureau est facilement accessible en voiture depuis la route 138 et l'autoroute 40. Un stationnement est disponible à proximité." },
  { question: "Est-ce possible d'avoir un rendez-vous le soir ou la fin de semaine à Donnacona?", answer: "Oui. Bien que nos heures régulières soient du lundi au vendredi de 8 h 30 à 17 h, nous offrons des rendez-vous en soirée et les fins de semaine sur demande. Contactez-nous au 418-462-1010 pour vérifier les disponibilités." },
  { question: "AUDEX Avocats à Donnacona accepte-t-il l'aide juridique?", answer: "Pour savoir si vous êtes admissible à l'aide juridique et si nos avocats peuvent vous recevoir sous ce programme, appelez-nous au 418-462-1010. Nous pourrons vérifier votre admissibilité et vous orienter vers les ressources appropriées." },
];
---

<BaseLayout title={title} description={description} headerSolid>
  <HeroInternal
    title="Un avocat à Donnacona — proche de vous, à votre écoute"
    subtitle="Bureau au 100, route 138. Tous nos services juridiques, directement dans votre communauté."
    breadcrumb={[{ label: 'Avocat à Donnacona' }]}
  />

  <section class="section">
    <div class="container-audex">
      <div class="about-content">
        <h2>Votre cabinet d'avocats à Donnacona</h2>
        <p>AUDEX Avocats est fier d'être présent à Donnacona pour offrir un accès direct à des services juridiques de qualité. Notre bureau sur la route 138 est au cœur de la communauté, à quelques minutes de chez vous.</p>
        <p>Nous savons qu'avoir besoin d'un avocat peut être stressant. C'est pourquoi notre priorité est de rendre l'expérience aussi simple et humaine que possible. Pas besoin de se rendre à Québec — vous avez une équipe complète d'avocats à Donnacona.</p>
        <p>De la première consultation au règlement de votre dossier, nous sommes là pour vous écouter, vous conseiller et vous représenter avec rigueur et bienveillance.</p>
      </div>
    </div>
  </section>

  <ServicesGrid
    title="Services juridiques à Donnacona"
    subtitle="L'ensemble de nos champs de pratique est accessible à notre bureau de Donnacona."
    services={services}
    showBlurb
  />

  <section class="section">
    <div class="container-audex">
      <div class="contact-grid" style="grid-template-columns: 1fr;">
        <ContactInfo showOffices="donnacona" mapHeight={300} />
      </div>
    </div>
  </section>

  <FAQ title="Questions fréquentes — Avocat à Donnacona" items={faq} />

  <CtaBlock title="Prenez rendez-vous à Donnacona" />
</BaseLayout>
