---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroInternal from '../components/sections/HeroInternal.astro';
import ServicesGrid from '../components/sections/ServicesGrid.astro';
import ContactInfo from '../components/contact/ContactInfo.astro';
import FAQ from '../components/sections/FAQ.astro';
import CtaBlock from '../components/sections/CtaBlock.astro';
import { services } from '../data/services';

const title = "Avocat pour la MRC de Portneuf | AUDEX Avocats — Service à distance";
const description = "Avocat pour la région de Portneuf. AUDEX Avocats accompagne Donnacona, Pont-Rouge, Saint-Raymond, Cap-Santé et toute la MRC par téléphone et visioconférence. 418-462-1010.";

const faq = [
  { question: "Comment consulter un avocat d'AUDEX dans la région de Portneuf?", answer: "Toutes nos consultations pour la MRC de Portneuf se déroulent par téléphone ou visioconférence — vous n'avez pas à vous déplacer à Québec. Nous desservons Donnacona, Pont-Rouge, Saint-Raymond, Cap-Santé, Neuville, Saint-Basile, Deschambault-Grondines et les municipalités environnantes." },
  { question: "Quels services juridiques sont disponibles pour les résidents de Portneuf?", answer: "Tous nos champs de pratique sont accessibles aux résidents de Portneuf : droit familial, médiation familiale, droit civil, droit commercial, droit criminel et pénal, droit administratif, droit municipal, droit de l'emploi et droit de la jeunesse. La consultation à distance vous donne accès à la même expertise que nos clients de Québec." },
  { question: "Est-ce que je peux consulter un avocat sans me déplacer?", answer: "Absolument. Notre service est conçu pour s'adapter à votre horaire et à votre emplacement. Vous pouvez prendre rendez-vous en appelant le 418-462-1010 ou en remplissant notre formulaire en ligne. La consultation se déroule ensuite par téléphone ou Microsoft Teams, selon votre préférence." },
  { question: "La consultation à distance est-elle aussi efficace qu'une rencontre en personne?", answer: "Oui. Pour la grande majorité des dossiers, la consultation à distance est tout aussi rigoureuse — et beaucoup plus pratique. Vous économisez le déplacement, votre dossier avance plus vite, et vous bénéficiez de la même écoute et des mêmes conseils que nos clients sur place." },
  { question: "AUDEX Avocats dessert-il Saint-Raymond et Pont-Rouge?", answer: "Oui, absolument. Nous accompagnons l'ensemble de la MRC de Portneuf, incluant Saint-Raymond, Pont-Rouge, Cap-Santé, Neuville, Saint-Basile et toutes les municipalités de la région. Les consultations par téléphone et visioconférence vous évitent tout déplacement." },
];
---

<BaseLayout title={title} description={description} headerSolid>
  <HeroInternal
    title="Votre avocat pour la région de Portneuf"
    subtitle="Service à distance pour Donnacona, Pont-Rouge, Saint-Raymond, Cap-Santé et toute la MRC de Portneuf. Première consultation à tarif fixe."
    breadcrumb={[{ label: 'Avocat à Portneuf' }]}
  />

  <section class="section">
    <div class="container-audex">
      <div class="about-content">
        <h2>Un avocat accessible aux résidents de Portneuf</h2>
        <p>Pas besoin de se déplacer à Québec pour consulter un avocat de confiance. AUDEX Avocats offre un service juridique complet à l'ensemble de la MRC de Portneuf, par téléphone et visioconférence.</p>
        <p>Que vous soyez de Donnacona, Pont-Rouge, Saint-Raymond, Cap-Santé, Neuville ou Saint-Basile, notre équipe est à votre portée. Nous comprenons les réalités des communautés de Portneuf et nous adaptons notre approche en conséquence.</p>
        <p>Notre engagement : une écoute authentique, des conseils clairs et un accompagnement juridique rigoureux — avec la commodité d'une consultation à distance, depuis votre domicile.</p>
      </div>
    </div>
  </section>

  <ServicesGrid
    title="Nos champs de pratique"
    subtitle="Tous nos services juridiques sont accessibles aux résidents de la MRC de Portneuf, par téléphone ou visioconférence."
    services={services}
    showBlurb
  />

  <section class="section">
    <div class="container-audex">
      <div class="contact-grid" style="grid-template-columns: 1fr;">
        <ContactInfo showOffices="none" remoteServiceArea="de la MRC de Portneuf" />
      </div>
    </div>
  </section>

  <FAQ title="Questions fréquentes — Avocat à Portneuf" items={faq} />

  <CtaBlock title="Discutez avec un avocat — sans vous déplacer" />
</BaseLayout>
