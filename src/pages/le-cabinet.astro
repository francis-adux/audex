---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroInternal from '../components/sections/HeroInternal.astro';
import ValuesSection from '../components/sections/ValuesSection.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import CtaBlock from '../components/sections/CtaBlock.astro';

const entry = await getEntry('pages', 'le-cabinet');
if (!entry) throw new Error('Missing pages/le-cabinet.md');
const { Content } = await entry.render();
const d = entry.data;
---

<BaseLayout title={d.title} description={d.description} headerSolid>
  <HeroInternal
    title={d.heroTitle}
    subtitle={d.heroSubtitle}
    image={d.heroImage}
    imageWebp={d.heroImageWebp}
    imageAlt={d.heroImageAlt}
    breadcrumb={[{ label: 'Le cabinet' }]}
  />

  <section class="section">
    <div class="container-audex">
      <div class="about-content">
        <Content />
      </div>
    </div>
  </section>

  <ValuesSection />

  <TrustBar items={[
    { type: 'year', label: 'Fondé en 2013' },
    { type: 'offices', label: '2 bureaux' },
    { type: 'barreau', label: 'Barreau du Québec' },
    { type: 'mediation', label: 'Médiation familiale accréditée' },
    { type: 'bilingue', label: 'Français et anglais' },
  ]} />

  <CtaBlock title="Discutez de votre situation avec notre équipe" />
</BaseLayout>
